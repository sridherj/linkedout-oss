# LinkedOut OSS — Fresh Install Sandbox
# Simulates a clean Ubuntu machine. Only pre-installs what a typical
# developer machine would already have (Python, git, curl). Everything
# else (PostgreSQL, pgvector, etc.) is installed by /linkedout-setup.
#
# Claude credentials are baked in at build time. Rebuild when they expire.
#
# Usage:
#   linkedout-sandbox              # build + run
#   linkedout-sandbox --no-build   # reuse existing image

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

# ── Minimal deps: what a dev machine would already have ──────────
RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
      ca-certificates curl git sudo \
      python3 python3-pip python3-venv \
      build-essential && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# ── Non-root user (Claude Code refuses bypassPermissions as root) ─
RUN usermod -l sandbox -d /home/sandbox -m ubuntu && \
    groupmod -n sandbox ubuntu && \
    echo 'sandbox ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/sandbox

# ── Claude Code (native installer — no Node.js needed) ──────────
USER sandbox
ENV PATH="/home/sandbox/.local/bin:${PATH}"
RUN curl -fsSL https://claude.ai/install.sh | bash

# ── Claude credentials + onboarding (baked at build time) ────────
ARG CLAUDE_CREDENTIALS_JSON
RUN mkdir -p /home/sandbox/.claude && \
    echo "$CLAUDE_CREDENTIALS_JSON" > /home/sandbox/.claude/.credentials.json && \
    chmod 600 /home/sandbox/.claude/.credentials.json && \
    python3 -c "import json,pathlib;p=pathlib.Path('/home/sandbox/.claude.json');d=json.loads(p.read_text()) if p.exists() else {};d['hasCompletedOnboarding']=True;d['lastOnboardingVersion']='2.1.97';d.setdefault('projects',{})['/linkedout-oss']={'hasTrustDialogAccepted':True};p.write_text(json.dumps(d,indent=2))"

# ── Claude Code headless config ─────────────────────────────────
RUN echo '{ \
      "skipDangerousModePermissionPrompt": true, \
      "effortLevel": "medium", \
      "permissions": { \
        "allow": ["Bash(*)", "Read", "Edit", "Write", "Glob", "Grep"], \
        "defaultMode": "bypassPermissions" \
      } \
    }' > /home/sandbox/.claude/settings.json

# ── Clone the repo and install skills ────────────────────────────
USER root
ARG CACHE_BUST=1
RUN git clone https://github.com/sridherj/linkedout-oss.git /linkedout-oss && \
    chown -R sandbox:sandbox /linkedout-oss

WORKDIR /linkedout-oss

# Copy local setup script (may not be on GitHub yet)
COPY setup /linkedout-oss/setup
RUN chown sandbox:sandbox /linkedout-oss/setup

USER sandbox

# ── Entrypoint (prints banner, drops to shell) ───────────────────
USER root
RUN printf '#!/usr/bin/env bash\n\
set -e\n\
echo ""\n\
echo "============================================"\n\
echo "  LinkedOut Fresh Install Sandbox"\n\
echo "============================================"\n\
echo ""\n\
echo "  Python:  $(python3 --version)"\n\
echo "  Claude:  $(claude --version 2>/dev/null || echo not found)"\n\
echo "  Repo:    /linkedout-oss (already cloned)"\n\
echo ""\n\
echo "  Next steps:"\n\
echo "    1. Run: ./setup"\n\
echo "    2. Install any missing prerequisites it reports"\n\
echo "    3. Re-run ./setup (installs skills)"\n\
echo "    4. Run: claude"\n\
echo "    5. Invoke /linkedout-setup"\n\
echo ""\n\
echo "  Each docker run is a clean slate."\n\
echo "============================================"\n\
echo ""\n\
if [ $# -gt 0 ]; then exec "$@"; else exec bash -l; fi\n' > /entrypoint.sh && chmod +x /entrypoint.sh

USER sandbox
ENTRYPOINT ["/entrypoint.sh"]
