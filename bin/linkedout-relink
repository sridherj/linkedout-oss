#!/usr/bin/env python3
# SPDX-License-Identifier: Apache-2.0
"""Detect and fix broken LinkedOut skill symlinks in AI host directories.

Handles the "I moved the repo" case: after relocating the repo, symlinks
break. This script detects broken symlinks and re-creates them pointing
to the current repo location.

Usage:
    python bin/linkedout-relink
"""

from __future__ import annotations

import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(REPO_ROOT))

from skills.lib.config import list_hosts, load_host_config

# Routing file names per host
ROUTING_FILENAMES = {
    'claude': 'CLAUDE.md',
    'codex': 'AGENTS.md',
    'copilot': 'COPILOT.md',
}

SKILLS_DIR = REPO_ROOT / 'skills'


def get_output_dir(host_config: dict) -> Path:
    """Get the generated output directory for a host."""
    return SKILLS_DIR / host_config.get('output_dir', host_config['name'])


def check_and_fix_symlink(link: Path, expected_target: Path) -> str:
    """Check a symlink and fix if broken.

    Returns one of:
        "valid"     - symlink exists and target resolves
        "fixed"     - broken symlink fixed
        "not_linked"- no symlink exists
        "not_ours"  - symlink exists but doesn't point to our repo
    """
    if not link.is_symlink():
        if link.exists():
            return 'not_ours'
        return 'not_linked'

    # It's a symlink — check if it resolves
    try:
        resolved = link.resolve(strict=True)
        if resolved == expected_target.resolve():
            return 'valid'
        # Points somewhere else — not ours
        return 'not_ours'
    except OSError:
        pass

    # Broken symlink — fix it
    link.unlink()
    link.symlink_to(expected_target)
    return 'fixed'


def relink_host(host_name: str) -> None:
    """Check and fix skill symlinks for a single host."""
    host_config = load_host_config(host_name)
    install_path = Path(host_config['skill_install_path']).expanduser()
    output_dir = get_output_dir(host_config)
    display = host_config['display_name']

    if not output_dir.is_dir():
        print(f'  {display}: no generated output — run bin/generate-skills first')
        return

    valid = 0
    fixed = 0
    not_linked = 0

    # Check skill symlinks
    for skill_dir in sorted(output_dir.iterdir()):
        if not skill_dir.is_dir():
            continue
        link = install_path / skill_dir.name
        status = check_and_fix_symlink(link, skill_dir)
        if status == 'valid':
            valid += 1
        elif status == 'fixed':
            fixed += 1
        elif status == 'not_linked':
            not_linked += 1

    # Check routing symlink
    routing_filename = ROUTING_FILENAMES.get(host_name)
    if routing_filename:
        routing_source = output_dir / routing_filename
        if routing_source.exists():
            routing_link = install_path.parent / routing_filename
            status = check_and_fix_symlink(routing_link, routing_source)
            if status == 'valid':
                valid += 1
            elif status == 'fixed':
                fixed += 1
            elif status == 'not_linked':
                not_linked += 1

    parts = []
    if valid:
        parts.append(f'{valid} valid')
    if fixed:
        parts.append(f'{fixed} fixed')
    if not_linked:
        parts.append(f'{not_linked} not linked')
    summary = ', '.join(parts) or 'no skills found'
    print(f'  {display}: {summary}')

    if not_linked:
        print(f'    Run bin/dev-setup to create missing links')


def main() -> int:
    hosts = list_hosts()
    if not hosts:
        print('No host configs found.')
        return 0

    print('Checking LinkedOut skill symlinks...\n')
    for host_name in hosts:
        relink_host(host_name)

    print('\nDone.')
    return 0


if __name__ == '__main__':
    sys.exit(main())
