#!/usr/bin/env python3
# SPDX-License-Identifier: Apache-2.0
"""Generate host-specific skill files from SKILL.md.tmpl templates and ROUTING.md.tmpl.

Discovers all .tmpl files under skills/*, renders them for each host config
in skills/hosts/*.yaml, and writes the output to skills/<host>/<skill>/SKILL.md
(for skill templates) or skills/<host>/<routing-file> (for routing templates).

Usage:
    python bin/generate-skills            # Generate all skill files
    python bin/generate-skills --check    # Check generated files are up-to-date (CI mode)
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(REPO_ROOT))

from skills.lib.config import get_global_context, get_host_variables, list_hosts, load_host_config
from skills.lib.frontmatter import join_frontmatter, process_frontmatter, split_frontmatter
from skills.lib.template import load_template, render_template

GENERATED_HEADER = '<!-- Generated by bin/generate-skills — do not edit -->\n'

SKILLS_DIR = REPO_ROOT / 'skills'

# Mapping from host name to routing output filename
ROUTING_FILENAMES = {
    'claude': 'CLAUDE.md',
    'codex': 'AGENTS.md',
    'copilot': 'COPILOT.md',
}


def discover_skill_templates() -> list[tuple[str, Path]]:
    """Find all SKILL.md.tmpl files and return (skill_name, path) pairs."""
    templates = []
    for tmpl_path in sorted(SKILLS_DIR.glob('*/SKILL.md.tmpl')):
        skill_name = tmpl_path.parent.name
        # Skip output directories and lib
        if skill_name in ('claude-code', 'codex', 'copilot', 'lib', 'hosts', 'routing'):
            continue
        templates.append((skill_name, tmpl_path))
    return templates


def discover_routing_template() -> Path | None:
    """Find the ROUTING.md.tmpl file if it exists."""
    routing_path = SKILLS_DIR / 'routing' / 'ROUTING.md.tmpl'
    return routing_path if routing_path.exists() else None


def apply_path_rewrites(content: str, host_config: dict) -> str:
    """Apply path rewrites defined in host config."""
    for rewrite in host_config.get('path_rewrites', []):
        content = content.replace(rewrite['from'], rewrite['to'])
    return content


def apply_tool_rewrites(content: str, host_config: dict) -> str:
    """Apply tool name rewrites defined in host config."""
    for old_name, new_name in host_config.get('tool_rewrites', {}).items():
        content = content.replace(old_name, new_name)
    return content


def render_skill(tmpl_path: Path, host_config: dict, variables: dict[str, str]) -> str:
    """Render a single skill template for a host, applying all transformations."""
    template = load_template(str(tmpl_path))

    # Add skill-specific variables
    skill_vars = dict(variables)
    skill_vars['SKILL_NAME'] = tmpl_path.parent.name

    # Render template (conditionals + variables)
    rendered = render_template(template, skill_vars)

    # Process frontmatter per host rules
    frontmatter, body = split_frontmatter(rendered)
    if frontmatter:
        processed_fm = process_frontmatter(frontmatter, host_config)
        rendered = join_frontmatter(processed_fm, body)

    # Apply path and tool rewrites
    rendered = apply_path_rewrites(rendered, host_config)
    rendered = apply_tool_rewrites(rendered, host_config)

    return GENERATED_HEADER + rendered


def render_routing(tmpl_path: Path, host_config: dict, variables: dict[str, str]) -> str:
    """Render the routing template for a host."""
    template = load_template(str(tmpl_path))
    rendered = render_template(template, variables)
    rendered = apply_path_rewrites(rendered, host_config)
    rendered = apply_tool_rewrites(rendered, host_config)
    return GENERATED_HEADER + rendered


def generate_all() -> list[tuple[Path, str]]:
    """Generate all skill and routing files. Returns list of (output_path, content)."""
    skill_templates = discover_skill_templates()
    routing_template = discover_routing_template()
    hosts = list_hosts()
    global_context = get_global_context()
    outputs: list[tuple[Path, str]] = []

    for host_name in hosts:
        host_config = load_host_config(host_name)
        variables = get_host_variables(host_config, global_context)
        host_output_dir = SKILLS_DIR / host_config.get('output_dir', host_config['name'])

        # Generate skill files
        for skill_name, tmpl_path in skill_templates:
            content = render_skill(tmpl_path, host_config, variables)
            output_path = host_output_dir / skill_name / 'SKILL.md'
            outputs.append((output_path, content))

        # Generate routing file
        if routing_template:
            routing_filename = ROUTING_FILENAMES.get(host_name)
            if routing_filename:
                content = render_routing(routing_template, host_config, variables)
                output_path = host_output_dir / routing_filename
                outputs.append((output_path, content))

    return outputs


def write_outputs(outputs: list[tuple[Path, str]]) -> int:
    """Write all generated files to disk. Returns count of files written."""
    count = 0
    for output_path, content in outputs:
        output_path.parent.mkdir(parents=True, exist_ok=True)
        output_path.write_text(content, encoding='utf-8')
        count += 1
    return count


def check_outputs(outputs: list[tuple[Path, str]]) -> list[str]:
    """Check generated files match expected content. Returns list of drift messages."""
    drifted = []
    for output_path, expected in outputs:
        if not output_path.exists():
            drifted.append(f'Missing: {output_path.relative_to(REPO_ROOT)}')
        else:
            actual = output_path.read_text(encoding='utf-8')
            if actual != expected:
                drifted.append(f'Drifted: {output_path.relative_to(REPO_ROOT)}')
    return drifted


def main() -> int:
    parser = argparse.ArgumentParser(description='Generate host-specific skill files')
    parser.add_argument(
        '--check',
        action='store_true',
        help='Check generated files are up-to-date (exit 1 if drifted)',
    )
    args = parser.parse_args()

    outputs = generate_all()

    if args.check:
        drifted = check_outputs(outputs)
        if drifted:
            print('Generated skill files are out of date:', file=sys.stderr)
            for msg in drifted:
                print(f'  {msg}', file=sys.stderr)
            print(f'\nRun `python bin/generate-skills` to regenerate.', file=sys.stderr)
            return 1
        print(f'All {len(outputs)} generated files are up to date.')
        return 0

    count = write_outputs(outputs)
    print(f'Generated {count} files across {len(list_hosts())} hosts.')
    return 0


if __name__ == '__main__':
    sys.exit(main())
