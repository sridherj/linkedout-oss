#!/usr/bin/env python3
# SPDX-License-Identifier: Apache-2.0
"""Generate skills/linkedout/schema-reference.md from SQLAlchemy entity metadata."""

import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(REPO_ROOT / "backend" / "src"))

OUTPUT = REPO_ROOT / "skills" / "linkedout" / "schema-reference.md"
HEADER = "<!-- Auto-generated by bin/generate-schema-ref — do not edit -->\n\n"

try:
    from linkedout.intelligence.schema_context import build_schema_context

    content = HEADER + build_schema_context()
    OUTPUT.parent.mkdir(parents=True, exist_ok=True)
    OUTPUT.write_text(content, encoding="utf-8")
    print(f"Wrote {OUTPUT}")
except Exception as exc:
    print(f"Warning: could not generate schema reference: {exc}", file=sys.stderr)
    print("Skipping generation — existing schema-reference.md (if any) is still valid.")
    sys.exit(0)
