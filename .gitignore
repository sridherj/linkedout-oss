# ============================================
# LinkedOut OSS — Root .gitignore
# ============================================
# Backend-specific patterns are in backend/.gitignore.
# This file covers repo-wide and cross-project patterns.

# ---------- Environment & secrets ----------
.env
.env.*
!.env.example
!backend/.env.test
secrets.yaml
*.secret
*.key

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/

# ---------- Node / TypeScript (extension) ----------
node_modules/
.output/
.wxt/

# ---------- Data files ----------
*.sqlite
*.sqlite3
*.db
# Allow the synthetic test fixtures (no PII — generated by generate_test_seed.py)
!backend/tests/fixtures/test-seed.dump
!backend/tests/fixtures/seed-manifest.json

# ---------- IDE configs ----------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ---------- Logs & reports ----------
*.log
logs/

# ---------- Testing ----------
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# ---------- E2E test fixtures (real PII — never commit) ----------
tests/e2e/fixtures/

# ---------- Seed data files (published as GitHub Release assets) ----------
seed-data/*.dump
seed-data/*.sqlite
seed-data/*.db
seed-data/seed-manifest.json

# ---------- TaskOS specific ----------
.taskos
.claude/agents/taskos-*
.claude/commands/taskos-*

# ---------- Personal Claude Code config (machine-specific hook paths) ----------
.claude/settings.json
.claude/hooks/

# ---------- Private second-brain symlinks (machine-specific) ----------
backend/.claude/
backend/src/.claude/

# ---------- Claude session artifacts (auto-generated, never commit) ----------
**/plan_and_progress/

# ---------- Demo seed generation (maintainer-only, not shipped) ----------
scripts/generate-demo-dump.py

# ---------- One-time migration artifacts ----------
scripts/migrate-from-private.sh
backend/data/

# ---------- E2E tests (WIP) ----------
tests/e2e/
