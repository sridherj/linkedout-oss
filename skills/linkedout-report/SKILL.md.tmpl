### 2. Query Activity

**Source:** `$DATA_DIR/queries/*.jsonl`

```bash
ls "$DATA_DIR/queries/"*.jsonl 2>/dev/null | head -5
```

If no JSONL files exist, print:
> **Query Activity:** No query history yet. Try: `/linkedout "who do I know at Google?"`

Otherwise, compute and display:

```bash
python3 -c "
import json, os, sys
from datetime import datetime, timedelta
from collections import Counter
from pathlib import Path

data_dir = os.environ.get('LINKEDOUT_DATA_DIR', os.path.expanduser('~/linkedout-data'))
queries_dir = Path(data_dir) / 'queries'

entries = []
for f in sorted(queries_dir.glob('*.jsonl')):
    for line in f.read_text().splitlines():
        try:
            entries.append(json.loads(line))
        except json.JSONDecodeError:
            pass

total = len(entries)
if total == 0:
    print('No query data found.')
    sys.exit(0)

# Queries this week
week_ago = (datetime.utcnow() - timedelta(days=7)).isoformat()
week_count = sum(1 for e in entries if e.get('timestamp', '') >= week_ago)

# Query types
types = Counter(e.get('query_type', 'general') for e in entries)

# Avg results
results = [e.get('result_count', 0) for e in entries if 'result_count' in e]
avg_results = sum(results) / len(results) if results else 0

# Recent sessions
sessions = {}
for e in entries:
    sid = e.get('session_id', 'unknown')
    ts = e.get('timestamp', '')
    if sid not in sessions:
        sessions[sid] = {'count': 0, 'first': ts, 'last': ts}
    sessions[sid]['count'] += 1
    if ts > sessions[sid]['last']:
        sessions[sid]['last'] = ts

print(f'Total queries:         {total}')
print(f'Queries this week:     {week_count}')
print(f'Avg results/query:     {avg_results:.1f}')
print()
print('Query types:')
for qt, count in types.most_common(10):
    print(f'  {qt + \":\":21s}{count}')
print()
recent = sorted(sessions.items(), key=lambda x: x[1]['last'], reverse=True)[:5]
if recent:
    print('Recent sessions:')
    for sid, info in recent:
        print(f'  {info[\"last\"][:10]}  {info[\"count\"]} queries  (session {sid[:8]}...)')
"
```

Format as:

```
== Query Activity ==

Total queries:         142
Queries this week:     23
Avg results/query:     4.7

Query types:
  general:             47
  company_lookup:      45
  person_search:       32
  semantic_search:     18

Recent sessions:
  2026-04-07  12 queries  (session a1b2c3d4...)
  2026-04-05  8 queries   (session e5f6a7b8...)
```

