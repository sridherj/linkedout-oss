# ┌──────────────────────────────────────────────────────────┐
# │  LinkedOut OSS — Environment Variables                    │
# │  Copy to .env and fill in values.                         │
# │  Preferred: use ~/linkedout-data/config/config.yaml instead.         │
# │  Full reference: docs/configuration.md                    │
# └──────────────────────────────────────────────────────────┘

# ── Database (required) ──────────────────────────────────────
DATABASE_URL=postgresql://linkedout:YOUR_PASSWORD@localhost:5432/linkedout

# ── Core ─────────────────────────────────────────────────────
# LINKEDOUT_DATA_DIR=~/linkedout-data
# LINKEDOUT_ENVIRONMENT=local             # local | test | prod
# LINKEDOUT_DEBUG=false

# ── Embeddings (nested — use double underscore) ─────────────
# LINKEDOUT_EMBEDDING__PROVIDER=openai    # openai | local
# LINKEDOUT_EMBEDDING__MODEL=text-embedding-3-small
# LINKEDOUT_EMBEDDING__DIMENSIONS=1536    # 1536 for OpenAI, 768 for local/nomic
# LINKEDOUT_EMBEDDING__CHUNK_SIZE=5000
# LINKEDOUT_EMBEDDING__BATCH_TIMEOUT_SECONDS=7200
# LINKEDOUT_EMBEDDING__BATCH_POLL_INTERVAL_SECONDS=30

# ── API Keys ─────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...                  # required if embedding provider=openai
#
# Apify keys for LinkedIn profile enrichment (optional).
# Single key:
# APIFY_API_KEY=apify_api_...
#
# Multiple keys for round-robin rotation (spreads rate limits across accounts).
# Comma-separated — each enrichment call rotates to the next key:
# APIFY_API_KEYS=apify_api_aaa,apify_api_bbb,apify_api_ccc
#
# Or as a YAML list in secrets.yaml:
#   apify_api_keys:
#     - apify_api_aaa
#     - apify_api_bbb

# ── LLM (nested — use double underscore) ────────────────────
# LINKEDOUT_LLM__PROVIDER=openai
# LINKEDOUT_LLM__MODEL=gpt-5.2-2025-12-11
# LINKEDOUT_LLM__SEARCH_MODEL=gpt-5.4-mini
# LINKEDOUT_LLM__TIMEOUT_SECONDS=120.0
# LINKEDOUT_LLM__RETRY_MAX_ATTEMPTS=3
# LINKEDOUT_LLM__RETRY_MIN_WAIT=2.0
# LINKEDOUT_LLM__RETRY_MAX_WAIT=30.0
# LINKEDOUT_LLM__RATE_LIMIT_RPM=60
# LINKEDOUT_LLM__PROMPT_CACHE_TTL_SECONDS=300
# LINKEDOUT_LLM__SUMMARIZE_BEYOND_N_TURNS=4

# ── Server ───────────────────────────────────────────────────
# LINKEDOUT_BACKEND_PORT=8001
# LINKEDOUT_BACKEND_HOST=localhost
# LINKEDOUT_BACKEND_URL=http://localhost:8001  # computed from host+port if not set
# LINKEDOUT_CORS_ORIGINS=                      # comma-separated allowed origins

# ── Logging ──────────────────────────────────────────────────
# LINKEDOUT_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
# LINKEDOUT_LOG_FORMAT=human             # human | json
# LINKEDOUT_LOG_DIR=~/linkedout-data/logs
# LINKEDOUT_METRICS_DIR=~/linkedout-data/metrics
# LINKEDOUT_DB_ECHO_LOG=false

# ── Log Rotation ─────────────────────────────────────────────
# LINKEDOUT_LOG_ROTATION=50 MB
# LINKEDOUT_LOG_RETENTION=30 days

# ── Scoring (nested — use double underscore) ─────────────────
# LINKEDOUT_SCORING__WEIGHT_CAREER_OVERLAP=0.40
# LINKEDOUT_SCORING__WEIGHT_EXTERNAL_CONTACT=0.25
# LINKEDOUT_SCORING__WEIGHT_EMBEDDING_SIMILARITY=0.15
# LINKEDOUT_SCORING__WEIGHT_SOURCE_COUNT=0.10
# LINKEDOUT_SCORING__WEIGHT_RECENCY=0.10
# LINKEDOUT_SCORING__DUNBAR_INNER_CIRCLE=15
# LINKEDOUT_SCORING__DUNBAR_ACTIVE=50
# LINKEDOUT_SCORING__DUNBAR_FAMILIAR=150
# LINKEDOUT_SCORING__CAREER_NORMALIZATION_MONTHS=36

# ── Enrichment (nested — use double underscore) ──────────────
# LINKEDOUT_ENRICHMENT__APIFY_BASE_URL=https://api.apify.com/v2
# LINKEDOUT_ENRICHMENT__CACHE_TTL_DAYS=90
# LINKEDOUT_ENRICHMENT__COST_PER_PROFILE_USD=0.004
# LINKEDOUT_ENRICHMENT__SYNC_TIMEOUT_SECONDS=60
# LINKEDOUT_ENRICHMENT__ASYNC_START_TIMEOUT_SECONDS=30
# LINKEDOUT_ENRICHMENT__RUN_POLL_TIMEOUT_SECONDS=300
# LINKEDOUT_ENRICHMENT__RUN_POLL_INTERVAL_SECONDS=5
# LINKEDOUT_ENRICHMENT__FETCH_RESULTS_TIMEOUT_SECONDS=30
# LINKEDOUT_ENRICHMENT__KEY_VALIDATION_TIMEOUT_SECONDS=15

# ── External API Defaults (nested) ──────────────────────────
# LINKEDOUT_EXTERNAL_API__RETRY_MAX_ATTEMPTS=3
# LINKEDOUT_EXTERNAL_API__TIMEOUT_SECONDS=30.0

# ── Pagination ───────────────────────────────────────────────
# LINKEDOUT_DEFAULT_PAGE_SIZE=20

# ── Extension Tuning ─────────────────────────────────────────
# LINKEDOUT_RATE_LIMIT_HOURLY=30
# LINKEDOUT_RATE_LIMIT_DAILY=150
# LINKEDOUT_STALENESS_DAYS=30
# LINKEDOUT_ENRICHMENT_CACHE_TTL_DAYS=90

# ── Observability (off by default) ───────────────────────────
# LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

# ── Extension Build-Time ─────────────────────────────────────
# VITE_BACKEND_URL=http://localhost:8001  # baked into extension at build time
